<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Developer ID + Hardened Runtime build.
         No App Sandbox: Claude Shell needs to spawn user-installed CLIs
         (claude, ngrok, devtunnel, cloudflared) found on PATH, which
         the sandbox forbids regardless of file-picker entitlements.
         Hardened Runtime requires no exceptions for this app — it does
         not JIT, allocate unsigned executable memory, dlopen unsigned
         dylibs, or read DYLD_* environment variables. -->
</dict>
</plist>
